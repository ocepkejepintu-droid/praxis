# Agent Praxis local secrets. Do not commit real .env values.
AGENT_PRAXIS_TOKEN=
HERMES_INGEST_TOKEN=

# School/LMS ACP adapter.
# Use mock-school for local end-to-end QA without real credentials.
SCHOOL_ACP_PROVIDER=mock-school
SCHOOL_ACP_BASE_URL=
SCHOOL_ACP_API_KEY=
SCHOOL_ACP_OAUTH_TOKEN=

# Praxis Learning real runtime placeholders.
# Real execution stays blocked unless repo code implements an approved RuntimeRunner.
REAL_PRAXIS_RUNTIME_RUNNER=
HERMES_LEARNER_COMMAND_ALLOWLIST=
HERMES_LEARNER_WORKSPACE_DIR=
OPENCLAW_LEARNER_COMMAND_ALLOWLIST=
OPENCLAW_LEARNER_WORKSPACE_DIR=
# Week 1 RuntimeRunner read-only contract foundation.
# Read-only can inspect workflows/logs/state only; real execution remains disabled.
HERMES_RUNTIME_MODE=
HERMES_READONLY_WORKSPACE_DIR=
HERMES_READONLY_WORKFLOW_DIR=
HERMES_READONLY_LOG_DIR=
HERMES_READONLY_STATE_DIR=
OMX_RUNTIME_MODE=
OMX_READONLY_WORKSPACE_DIR=
